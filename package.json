{
  "name": "metro-kyiv-pwa",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "start": "vite preview",
    "preview": "vite preview",
    "test": "npm run build && npm run test:model && npm run test:ui",
    "test:model": "node --experimental-strip-types --test tests/*.test.mjs",
    "test:ui": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "sync:transit": "node scripts/build-transit-data.mjs && node scripts/enrich-transit-data.mjs && node scripts/add-regional-transit.mjs",
    "check:bundle": "node scripts/check-bundle.mjs",
    "test:smoke": "node scripts/production-smoke.mjs",
    "check:production": "npm run lint && npm run build && npm run check:bundle && npm run test:smoke"
  },
  "dependencies": {
    "maplibre-gl": "^6.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260723.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.55.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "type": "module"
}
