{
  "name": "metro-kyiv-pwa",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "start": "vite preview",
    "preview": "vite preview",
    "test": "npm run build && node --test tests/static-build.test.mjs",
    "lint": "tsc --noEmit",
    "check:bundle": "node scripts/check-bundle.mjs",
    "test:smoke": "node scripts/production-smoke.mjs",
    "check:production": "npm run lint && npm run build && npm run check:bundle && npm run test:smoke"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "5.9.3",
    "vite": "8.0.13"
  },
  "type": "module"
}
